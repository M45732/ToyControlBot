// Prisma schema for the Discord bot rewrite.
//
// Models are added intentionally as features are migrated. The legacy bot used
// MySQL with tables such as `token_balance`, `token_history`, `daily_token`,
// `toycontrol`, `toycontrol_user`, and `toycontrol_tip_history`. See
// `docs/feature-map.md` and `docs/migration-notes.md` for the migration plan
// and the redesigned data model.
//
// Keep schema changes intentional and use migrations. Do not store unnecessary
// personal data.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// A user's current token balance within a guild.
model TokenBalance {
  id        String   @id @default(cuid())
  guildId   String
  userId    String
  balance   Int      @default(0)
  updatedAt DateTime @updatedAt

  @@unique([guildId, userId])
  @@index([guildId, balance])
}

/// An append-only ledger of every token balance change, for history views and auditing.
model TokenHistory {
  id        String   @id @default(cuid())
  guildId   String
  userId    String
  amount    Int
  eventType String
  eventId   String?
  createdAt DateTime @default(now())

  @@index([guildId, userId, createdAt])
}

/// Tracks the last daily-token redemption per user, per guild, for the 24h cooldown and streak.
model DailyToken {
  id          String   @id @default(cuid())
  guildId     String
  userId      String
  lastRedeem  DateTime
  streakDays  Int      @default(1)

  @@unique([guildId, userId])
}

/// An active reaction-vote toy control session (gangbang or orgy mode).
model ToyControl {
  id          String   @id @default(cuid())
  guildId     String
  channelId   String
  messageId   String   @unique
  ownerId     String
  sessionMode String   // "gangbang" | "orgy"
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())

  participants ToyControlUser[]

  @@index([guildId, active])
}

/// A participant in a ToyControl session.
model ToyControlUser {
  id        String   @id @default(cuid())
  sessionId String
  userId    String
  createdAt DateTime @default(now())

  session ToyControl @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, userId])
}

/// A control-link raffle posted in a guild channel.
/// The link URL is stored here so the raffle survives bot restarts.
model Raffle {
  id           String              @id @default(cuid())
  messageId    String              @unique
  channelId    String
  guildId      String
  hostId       String
  linkUrl      String
  linkProvider String
  active       Boolean             @default(true)
  createdAt    DateTime            @default(now())
  participants RaffleParticipant[]

  @@index([guildId, active])
}

/// A user who has entered a Raffle.
model RaffleParticipant {
  id       String @id @default(cuid())
  raffleId String
  userId   String
  raffle   Raffle @relation(fields: [raffleId], references: [id], onDelete: Cascade)

  @@unique([raffleId, userId])
}

/// A performer's paid subscription plan ("fanclub").
///
/// Access is granted by adding/removing the subscriber from a private Discord
/// thread (`threadId`) rather than a dedicated channel, so a guild can host
/// many fanclubs without hitting the per-guild channel limit. One active plan
/// per performer per guild.
model SubscriptionPlan {
  id          String   @id @default(cuid())
  guildId     String
  performerId String
  name        String
  description String?
  priceTokens Int
  threadId    String   @unique
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  subscriptions Subscription[]

  @@unique([guildId, performerId])
  @@index([guildId, active])
}

/// A member's subscription to a performer's plan.
///
/// `expiresAt` is the end of the currently paid period. The renewal sweep
/// re-charges `autoRenew` subscriptions whose period has ended, or marks them
/// `expired` (and revokes thread access) when auto-renew is off or the
/// subscriber can no longer afford the price.
model Subscription {
  id            String   @id @default(cuid())
  planId        String
  subscriberId  String
  status        String   @default("active") // "active" | "expired" | "cancelled"
  autoRenew     Boolean  @default(true)
  expiresAt     DateTime
  lastChargedAt DateTime @default(now())
  createdAt     DateTime @default(now())

  plan SubscriptionPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@unique([planId, subscriberId])
  @@index([status, expiresAt])
  @@index([subscriberId])
}

/// A tip transaction recorded during a toy-control tip session.
model TipHistory {
  id         String   @id @default(cuid())
  guildId    String
  messageId  String
  senderId   String
  receiverId String
  amount     Int
  message    String?
  createdAt  DateTime @default(now())

  @@index([guildId, messageId])
}
