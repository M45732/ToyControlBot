# Discord
DISCORD_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_GUILD_ID=

# Database
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/toycontrolbot?schema=public"

# Economy (optional role gates for the daily token command)
ROLE_VERIFIED_ID=
ROLE_PATRON=

# Lovense (toy control). Required for /toy-connect and /toy-status.
LOVENSE_API_TOKEN=
LOVENSE_API_BASE_URL=https://api.lovense-api.com

# Control-link channel restriction (optional).
# If set, toy-control links posted outside this channel are deleted.
CHAN_ID_TOY_LINK=

# Owner Discord user ID (optional). Required for /restart to be owner-only.
OWNER_DISCORD_ID=

# Runtime
NODE_ENV=development
LOG_LEVEL=debug
